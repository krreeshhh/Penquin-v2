        {
            "heading": "Reconnaissance & Asset Discovery",
            "subheadings": [
                {
                    "heading": "Infrastructure Fingerprinting",
                    "type": "list",
                    "content": [
                        "Identify S3 usage via web resource inspection (Burp Suite)",
                        "Check for requests to `https://[bucketname].s3.amazonaws.com`",
                        "Determine services in use: AD connectivity, mail gateways, web apps, file storage",
                        "Use `crt.sh` (Certificate Transparency) to find subdomains and TLDs",
                        "Search Engines (Google, Bing, etc.): `site:target.com -site:www.target.com`"
                    ]
                },
                {
                    "heading": "Cloud Recognition Tools",
                    "type": "code_block",
                    "content": [
                        "# CloudDetect - Determine the cloud provider of an IP",
                        "clouddetect -ip=151.101.1.68",
                        "",
                        "# Bucket finder tools",
                        "python3 cloud_enum.py -k example.com",
                        "ruby lazys3.rb companyname",
                        "slurp domain -t example.com"
                    ]
                }
            ]
        },
        {
            "heading": "S3 (Simple Storage Service)",
            "subheadings": [
                {
                    "heading": "S3 CLI Operations",
                    "type": "code_block",
                    "content": [
                        "aws s3 ls s3:// ",
                        "aws s3api list-buckets",
                        "aws s3 ls --recursive s3://bucket.com",
                        "aws s3 sync s3://bucketname s3-files-dir",
                        "aws s3 cp s3://bucket-name/file .",
                        "aws s3api get-bucket-acl --bucket bucket-name"
                    ]
                },
                {
                    "heading": "S3 Vulnerability Scanners",
                    "type": "list",
                    "content": [
                        "[S3Scanner](https://github.com/sa7mon/S3Scanner) - Audit S3 bucket permissions",
                        "[s3-buckets-finder](https://github.com/gwen001/s3-buckets-finder) - Brute force buckets",
                        "[AWSBucketDump](https://github.com/jordanpotti/AWSBucketDump) - Loot open S3 buckets"
                    ]
                },
                {
                    "heading": "Common S3 Attack Vectors",
                    "type": "list",
                    "content": [
                        "**S3 Bucket Pillaging**: Unauthorized data exfiltration from public buckets",
                        "**S3 Code Injection**: Injecting malicious JS into writeable buckets served by webapps",
                        "**Domain Hijacking**: Taking over buckets referenced by CNAMES that no longer exist (NoSuchBucket error)"
                    ]
                }
            ]
        },
        {
