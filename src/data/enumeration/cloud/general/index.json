        {
            "heading": "Recon & Discovery",
            "subheadings": [
                {
                    "heading": "DNS & Infrastructure Discovery",
                    "type": "code_block",
                    "content": [
                        "# Extracting domains from Forward DNS datasets (Rapid7 Sonar)",
                        "cat CNAME-DATASET-NAME | pigz -dc | grep -E \"\\.azurewebsites\\.com\"",
                        "cat CNAME-DATASET-NAME | pigz -dc | grep -E \"\\.s3\\.amazonaws\\.com\"",
                        "",
                        "# CloudDetect - Determine the cloud provider of a given IP",
                        "clouddetect -ip=151.101.1.68"
                    ]
                },
                {
                    "heading": "Discovery Checklist",
                    "type": "list",
                    "content": [
                        "Determine what services are in use (AD, mail gateways, web apps, file storage)",
                        "Microsoft, Amazon, Google IP space usually indicates cloud service usage",
                        "MX records can reveal cloud-hosted mail providers (O365, G-Suite, Proofpoint)",
                        "Certificate Transparency (crt.sh) to find additional subdomains and TLDs",
                        "Shodan/Censys query: org:\"Target Name\" or net:\"CIDR Range\""
                    ]
                },
                {
                    "heading": "Cloud Provider Netblocks",
                    "type": "list",
                    "content": [
                        "[Azure Netblocks (Public)](https://www.microsoft.com/en-us/download/details.aspx?id=56519)",
                        "[AWS Netblocks (JSON)](https://ip-ranges.amazonaws.com/ip-ranges.json)",
                        "[GCP Netblocks Search](https://cloud.google.com/compute/docs/faq#where_can_i_find_product_ip_ranges)"
                    ]
                }
            ]
        },
        {
            "heading": "Attack Phases",
            "subheadings": [
                {
                    "heading": "Foothold & Secret Hunting",
                    "type": "list",
                    "content": [
                        "[shhgit](https://github.com/eth0izzle/shhgit) - Find secrets in real-time",
                        "[GitLeaks](https://github.com/zricethezav/gitleaks) - Audit git repos for secrets",
                        "[TruffleHog](https://github.com/dxa4481/truffleHog) - Search high entropy strings",
                        "[PowerMeta](https://github.com/dafthack/PowerMeta) - Metadata extraction"
                    ]
                },
                {
                    "heading": "Web Server Exploitation",
                    "type": "code_block",
                    "content": [
                        "# Exporting certificates with Mimikatz",
                        "mimikatz# crypto::capi",
                        "mimikatz# privilege::debug",
                        "mimikatz# crypto::cng",
                        "mimikatz# crypto::certificates /systemstore:local_machine /store:my /export"
                    ]
                },
                {
                    "heading": "Post-Compromise Recon",
                    "type": "list",
                    "content": [
                        "Check current user roles and permissions",
                        "Identify if MFA is enabled",
                        "Audit accessible webapps and storage accounts",
                        "Identify administrators and potential escalation paths",
                        "Check for security protections (ATP, GuardDuty, etc.)"
                    ]
                }
            ]
        },
