                "https://gist.github.com/kurobeats/9a613c9ab68914312cbb415134795b45",
                "",
                "# Payload list",
                "https://github.com/m0chan/BugBounty/blob/master/xss-payload-list.txt",
                "",
                "https://github.com/terjanq/Tiny-XSS-Payloads",
                "",
                "# XSS to RCE",
