                }
            ]
        },
        {
            "heading": "Browser Behavior",
            "type": "table",
            "headers": [
                "Browser",
                "Default Behavior (2024+)"
            ],
            "rows": [
                {
                    "Browser": "Chrome 88+",
                    "Default Behavior (2024+)": "Implicitly adds noopener"
                },
                {
                    "Browser": "Firefox 79+",
                    "Default Behavior (2024+)": "Implicitly adds noopener"
                },
                {
                    "Browser": "Safari 12.1+",
                    "Default Behavior (2024+)": "Implicitly adds noopener"
                },
                {
                    "Browser": "Edge 88+",
                    "Default Behavior (2024+)": "Implicitly adds noopener"
                },
                {
                    "Browser": "> Note: While modern browsers add implicit protection, explicit rel=\"noopener\" is still recommended for older browser support and code clarity.",
                    "Default Behavior (2024+)": ""
                }
            ]
        },
        {
            "heading": "window.open() Vulnerability",
            "type": "code_block",
            "content": [
                "// VULNERABLE",
                "window.open('https://attacker.com');",
                "",
                "// SECURE",
                "window.open('https://external.com', '_blank', 'noopener,noreferrer');"
            ]
        },
