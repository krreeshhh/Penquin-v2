{
    "title": "iOS Security Testing",
    "breadcrumb": [
        {
            "title": "Mobile Security",
            "url": "/mobile"
        }
    ],
    "skill_level": "Intermediate to Advanced",
    "prerequisites": "Swift/ObjC basics, iOS security model",
    "sections": [
        {
            "heading": "Environment Setup & Prerequisites",
            "subheadings": [
                {
                    "heading": "Toolchain Configuration",
                    "type": "code_block",
                    "content": [
                        "# Install Xcode command line tools",
                        "xcode-select --install",
                        "",
                        "# Install core mobile testing utilities (macOS/Homebrew)",
                        "brew install libimobiledevice ideviceinstaller ios-deploy",
                        "",
                        "# Install runtime manipulation frameworks",
                        "pip3 install objection frida-tools",
                        "",
                        "# Verify device connectivity",
                        "idevice_id -l && ideviceinfo"
                    ]
                },
                {
                    "heading": "IPA Acquisition & Analysis",
                    "type": "code_block",
                    "content": [
                        "# Download decrypted IPAs from App Store",
                        "ipatool auth login -e email@example.com",
                        "ipatool download -b com.app.bundleid -o app.ipa",
                        "",
                        "# Static analysis via MobSF (Docker)",
                        "docker run -it --rm -p 8000:8000 opensecurity/mobile-security-framework-mobsf"
                    ]
                }
            ]
        },
        {
            "heading": "Runtime Manipulation (Non-Jailbreak)",
            "subheadings": [
                {
                    "heading": "Objection & IPA Patching",
                    "type": "code_block",
                    "content": [
                        "# Patch IPA with Frida gadget for side-loading",
                        "objection patchipa --source app.ipa --codesign-signature \"Apple Development: email@example.com\"",
                        "",
                        "# Deploy patched bundle to device",
                        "ios-deploy --bundle Payload/App.app",
                        "",
                        "# Common objection hooks",
                        "ios sslpinning disable        # Bypass SSL pinning",
                        "ios keychain dump             # Extract keychain items",
                        "ios jailbreak disable         # Bypass JB detection"
                    ]
                },
                {
                    "heading": "Frida Instrumentation",
                    "type": "code_block",
                    "content": [
                        "# List running applications",
                        "frida-ps -Ua",
                        "",
                        "# Spawn application with custom script",
                        "frida -U -f com.app.bundleid -l bypass.js --no-pause"
                    ]
                }
            ]
        },
        {
            "heading": "Security Analysis: Static & Dynamic",
            "subheadings": [
                {
                    "heading": "Binary Protections & Encryption",
                    "type": "code_block",
                    "content": [
                        "# Check for PIE, Stack Canaries, and ARC",
                        "otool -hv BINARY | grep PIE",
                        "otool -Iv BINARY | grep stack_chk",
                        "",
                        "# Verify binary encryption (cryptid 1 = encrypted)",
                        "otool -l BINARY | grep -A 4 LC_ENCRYPTION_INFO"
                    ]
                },
                {
                    "heading": "Filesystem & Data Audit",
                    "type": "code_block",
                    "content": [
                        "# Locate application data and bundle containers",
                        "find /var/mobile/Containers/Data/Application/ -name \"*.db\"",
                        "find /var/mobile/Containers/Data/Application/ -name \"*.plist\"",
                        "",
                        "# Extract NSUserDefaults configuration",
                        "ios nsuserdefaults get"
                    ]
                }
            ]
        },
        {
            "heading": "Common Vulnerabilities",
            "subheadings": [
                {
                    "heading": "Data Storage & Hardcoded Secrets",
                    "type": "list",
                    "content": [
                        "**Insecure Data Storage**: Sensitive info in `NSUserDefaults` or local `SQLite` databases.",
                        "**Hardcoded Credentials**: API keys, secrets, or tokens found via `strings` on binary.",
                        "**URL Scheme Injection**: Testing `myapp://` deep links for lack of input validation."
                    ]
                },
                {
                    "heading": "iOS 17-18 Security Features",
                    "type": "list",
                    "content": [
                        "**Lockdown Mode**: Enhanced JIT and attachment blocking for high-risk targets.",
                        "**Passkey Sharing**: Improved sync and AirDrop support for biometric auth.",
                        "**Contact Key Verification**: MITM prevention for iMessage/FaceTime."
                    ]
                }
            ]
        },
        {
            "heading": "Tools & Resource Summary",
            "subheadings": [
                {
                    "heading": "Comparison Table",
                    "type": "paragraph",
                    "content": "| Tool | Purpose | Jailbreak Required |\n|---|---|---|\n| Objection | Runtime manipulation, patching | No |\n| Frida | Dynamic instrumentation | Optional |\n| MobSF | Static analysis | No |\n| SSL Kill Switch | SSL pinning bypass | Yes |\n| Keychain-dumper| Keychain extraction | Yes |"
                }
            ]
        },
        {
            "heading": "Architecture Visualization",
            "type": "image",
