                {
                    "heading": "Get sensitive info",
                    "type": "code_block",
                    "content": [
                        "# Urls and secrets",
                        "# https://github.com/dwisiswant0/apkleaks",
                        "python apkleaks.py -f ~/path/to/file.apk",
