                    "heading": "Local Network Lab",
                    "type": "code_block",
                    "content": [
                        "# docker-compose.yml for network testing",
                        "version: '3'",
                        "services:",
                        "  router:",
                        "    image: alpine",
                        "    cap_add:",
                        "      - NET_ADMIN",
                        "    command: sh -c \"apk add iptables && tail -f /dev/null\"",
                        "    networks:",
                        "      internal:",
                        "        ipv4_address: 10.0.0.1",
                        "      external:",
                        "  ",
                        "  target1:",
                        "    image: vulnerables/web-dvwa",
                        "    networks:",
                        "      internal:",
                        "        ipv4_address: 10.0.0.10",
                        "  ",
                        "  target2:",
                        "    image: tleemcjr/metasploitable2",
                        "    networks:",
                        "      internal:",
                        "        ipv4_address: 10.0.0.11",
                        "",
                        "networks:",
                        "  internal:",
                        "    driver: bridge",
                        "    ipam:",
                        "      config:",
                        "        - subnet: 10.0.0.0/24",
                        "  external:",
                        "    driver: bridge"
                    ]
