                        "",
                        "# BLE CTF tools",
                        "# https://github.com/hackgnar/ble_ctf"
                    ]
                },
                {
                    "heading": "Bluetooth Sniffing",
                    "type": "code_block",
                    "content": [
                        "# Ubertooth",
                        "# https://github.com/greatscottgadgets/ubertooth",
                        "ubertooth-scan",
                        "ubertooth-btbb -f -c output.pcap",
                        "",
                        "# Analyze with Wireshark",
                        "wireshark -i ubertooth"
                    ]
                }
