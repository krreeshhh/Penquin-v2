                        "# Requires specialized hardware and software"
                    ]
                },
                {
                    "heading": "BLE (Bluetooth Low Energy)",
                    "type": "code_block",
                    "content": [
                        "# Scan for BLE devices",
                        "# https://github.com/securing/gattacker",
                        "hcitool lescan",
                        "",
