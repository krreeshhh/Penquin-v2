        {
            "heading": "Web Application Pentesting Mindmap",
            "type": "paragraph",
            "content": "Key areas to assess during web application security testing:"
        },
        {
            "heading": "Reconnaissance",
            "type": "list",
            "content": [
                "Subdomain enumeration",
                "Technology fingerprinting",
                "Hidden content discovery",
                "API endpoint mapping"
            ]
        },
        {
            "heading": "Authentication Testing",
            "type": "list",
            "content": [
                "Brute force protection",
                "Password policies",
                "Session management",
                "Multi-factor authentication bypass",
                "Account lockout mechanisms"
            ]
        },
        {
            "heading": "Authorization Testing",
            "type": "list",
            "content": [
                "Horizontal privilege escalation (IDOR)",
                "Vertical privilege escalation",
                "Function-level access control",
                "Insecure direct object references"
            ]
        },
        {
            "heading": "Input Validation",
            "type": "list",
            "content": [
                "SQL Injection (all types)",
                "XSS (Reflected, Stored, DOM)",
                "Command Injection",
                "SSRF / CSRF",
                "XXE Injection",
                "Template Injection (SSTI)"
            ]
        },
        {
            "heading": "Business Logic",
            "type": "list",
            "content": [
                "Workflow bypass",
                "Price manipulation",
                "Quantity tampering",
                "Feature abuse"
            ]
        },
        {
            "heading": "Infrastructure",
            "type": "paragraph",
            "content": "- Server misconfigurations\n- Default credentials\n- Exposed admin panels\n- Information disclosure\n)"
        },
        {
            "heading": "Bug Bounty Methodology",
