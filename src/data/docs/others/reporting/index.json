                        "docker run -d -p 3000:3000 dradis/dradis-ce",
                        "",
                        "# Ghostwriter - Report management",
                        "# https://github.com/GhostManager/Ghostwriter",
                        "docker-compose up",
                        "",
                        "# Pwndoc - Pentest report generator",
                        "# https://github.com/pwndoc/pwndoc",
                        "docker-compose up",
                        "",
                        "# Serpico - SimplE RePort wrIting and CollaboratiOn",
                        "# https://github.com/SerpicoProject/Serpico",
                        "docker-compose up"
                    ]
                },
                {
                    "heading": "Screenshot Tools",
                    "type": "code_block",
                    "content": [
                        "# Flameshot",
                        "flameshot gui",
                        "",
                        "# Greenshot (Windows)",
                        "# Capture with annotations",
                        "",
                        "# Terminal capture",
                        "script -q capture.txt",
                        "# Run commands",
                        "exit",
                        "# Output saved to capture.txt",
                        "",
                        "# asciinema for terminal recording",
                        "asciinema rec demo.cast"
                    ]
                }
            ]
        },
        {
            "heading": "Deliverables Checklist",
            "type": "code_block",
            "content": [
                "□ Executive Summary (PDF)",
                "□ Technical Report (PDF)",
                "□ Raw findings spreadsheet (Excel/CSV)",
                "□ Evidence archive (ZIP, encrypted)",
                "□ Remediation tracker",
                "□ Presentation slides (if required)",
                "□ Debrief meeting scheduled",
                "□ All credentials/access revoked",
                "□ Test data cleaned up"
            ]
        },
        {
            "heading": "Common Sections",
            "subheadings": [
                {
                    "heading": "Methodology Description",
                    "type": "paragraph",
                    "content": "```markdown"
                }
            ]
        },
        {
            "heading": "Testing Methodology",
            "type": "paragraph",
            "content": "This assessment followed industry-standard methodologies including:\n- OWASP Testing Guide v4.2 - Web application testing\n- PTES - Penetration Testing Execution Standard\n- NIST SP 800-115 - Technical Guide to Information Security Testing"
        },
        {
            "heading": "Phases:",
            "type": "paragraph",
            "content": "1. Reconnaissance - OSINT and passive information gathering\n2. Enumeration - Active scanning and service identification\n3. Vulnerability Analysis - Manual and automated testing\n4. Exploitation - Controlled exploitation of identified vulnerabilities\n5. Post-Exploitation - Impact assessment and lateral movement testing\n6. Reporting - Documentation and remediation guidance\n```"
        },
        {
            "heading": "Risk Rating Explanation",
            "type": "paragraph",
            "content": "```markdown"
        },
        {
            "heading": "Risk Rating Methodology",
            "type": "paragraph",
            "content": "Findings are rated based on:\n1. Likelihood of Exploitation\n- Skill level required\n- Availability of exploit code\n- Network accessibility\n2. Potential Impact\n- Confidentiality breach\n- Integrity compromise\n- Availability disruption\n- Business/regulatory impact\n3. Ease of Remediation\n- Quick fix vs. architectural change\n- Resource requirements\n- Potential for regression\n```"
        },
        {
