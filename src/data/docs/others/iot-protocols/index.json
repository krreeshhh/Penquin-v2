                        "# LoRa traffic analysis",
                        "# https://github.com/rpp0/gr-lora",
                        "",
                        "# Replay attacks (if no frame counter)",
                        "# ACK spoofing",
                        "# Bit-flipping attacks (if no integrity check)",
                        "",
                        "# Join request replay",
                        "# If DevNonce not checked, can replay join requests"
                    ]
                }
            ]
