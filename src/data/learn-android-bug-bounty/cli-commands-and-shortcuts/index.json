        {
          "Category": "Emulator Commands",
          "Command": "emulator -list-avds",
          "Description": "List available Android Virtual Devices"
        },
        {
          "Category": "",
          "Command": "emulator -avd New-Pixel_4 -writable-system -no-snapshot",
          "Description": "Start emulator with writable system"
        },
        {
          "Category": "",
          "Command": "emulator -avd Pixel_3a_Root -writable-system -no-snapshot -port 5560",
          "Description": "Start emulator on specific port"
        },
        {
          "Category": "MOBSF",
          "Command": "docker run -it --rm -p 8000:8000 -p 1337:1337 -e MOBSF_ANALYZER_IDENTIFIER=emulator-5554 opensecurity/mobile-security-framework-mobsf:latest",
          "Description": "Start MOBSF container"
        },
        {
          "Category": "ADB Commands",
          "Command": "adb shell pm list packages -3",
          "Description": "List 3rd party packages"
        },
        {
          "Category": "",
          "Command": "adb shell getprop ro.product.cpu.abi",
          "Description": "Get device CPU architecture"
        },
        {
          "Category": "",
          "Command": "adb push frida-server /data/local/tmp/",
          "Description": "Push file to device"
        },
        {
          "Category": "",
          "Command": "adb -s emulator-5560 push C:\\Users\\HP\\Downloads\\frida-server /data/local/tmp",
          "Description": "Push to specific emulator"
        },
        {
          "Category": "",
          "Command": "adb shell \"chmod +x /data/local/tmp/frida-server\"",
          "Description": "Make frida-server executable"
        },
        {
          "Category": "",
          "Command": "adb shell \"/data/local/tmp/frida-server &\"",
          "Description": "Start frida-server in background"
        },
        {
          "Category": "Frida Commands",
          "Command": "frida-ps -Uia",
          "Description": "List running apps on USB device"
        },
        {
          "Category": "",
          "Command": "frida -U -f com.target.app --no-pause -l ssl-pinning-bypass.js",
          "Description": "Inject script into app"
        },
        {
          "Category": "",
          "Command": "frida --codeshare dzonerzy/fridantiroot -f <package-name> -U",
          "Description": "Use anti-root detection script"
        },
        {
          "Category": "",
          "Command": "frida --codeshare masbog/frida-android-unpinning-ssl -f <package-name> -U",
          "Description": "Use SSL unpinning script"
        },
        {
          "Category": "Objection Commands",
          "Command": "objection-connect",
          "Description": "Connect to device"
        },
        {
          "Category": "",
          "Command": "objection-patch <my.apk>",
          "Description": "Patch APK for objection"
        },
        {
          "Category": "",
          "Command": "objection -g <package name> explore",
          "Description": "Explore app with objection"
        },
        {
          "Category": "",
          "Command": "android root disable",
          "Description": "Disable root detection"
        },
        {
          "Category": "",
          "Command": "android sslpinning disable",
          "Description": "Disable SSL pinning"
        },
        {
          "Category": "",
          "Command": "android hooking watch class <package-name>.UserMainActivity",
          "Description": "Watch class methods"
        },
        {
          "Category": "",
          "Command": "android hooking list classes",
          "Description": "List all classes"
        }
