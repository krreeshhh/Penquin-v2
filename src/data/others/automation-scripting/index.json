        {
            "heading": "The Offensive Pipeline (Tool Chaining)",
            "subheadings": [
                {
                    "heading": "Integrated Recon & Vulnerability Scan",
                    "type": "code_block",
                    "content": [
                        "#!/bin/bash",
                        "# Phase 1: Asset Discovery",
                        "subfinder -d \"$TARGET\" -silent | anew subs.txt",
                        "",
                        "# Phase 2: Vulnerability Detection (Nuclei)",
                        "cat subs.txt | httpx -silent | nuclei -severity medium,high,critical -o vulns.txt",
                        "",
                        "# Phase 3: Technology Fingerprinting",
                        "cat subs.txt | httpx -silent -tech-detect -json | jq -r '\"\\(.url) | \\(.tech)\"'"
                    ]
                }
            ]
