                    "heading": "Rapid Web & Credential Hunting",
                    "type": "code_block",
                    "content": [
                        "# Extract sensitive secrets from JS files",
                        "cat js_files.txt | xargs -I{} curl -s {} | grep -oE \"(api_key|token|auth)['\\\"]?\\\\s*[:=]\\\\s*['\\\"]?[a-zA-Z0-9_-]+\"",
                        "",
                        "# Find all subdomains via crt.sh (Certificate Transparency)",
                        "curl -s \"https://crt.sh/?q=%.$1&output=json\" | jq -r '.[].name_value' | sort -u",
                        "",
                        "# Search for AWS keys in current directory",
                        "grep -rE \"AKIA[0-9A-Z]{16}\" ."
                    ]
