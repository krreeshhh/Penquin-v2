                    "heading": "Multithreaded HTTP Request Template",
                    "type": "code_block",
                    "content": [
                        "from concurrent.futures import ThreadPoolExecutor",
                        "import requests",
                        "",
                        "def make_request(url):",
                        "    try:",
                        "        resp = requests.get(url, timeout=10, verify=False)",
                        "        print(f\"[{resp.status_code}] {url} ({len(resp.content)} bytes)\")",
                        "    except Exception as e: pass",
                        "",
                        "with ThreadPoolExecutor(max_workers=20) as executor:",
                        "    executor.map(make_request, url_list)"
                    ]
                },
                {
                    "heading": "Dynamic SQLi & Takeover Detection",
                    "type": "code_block",
                    "content": [
                        "# Fingerprinting for subdomain takeover",
                        "FINGERPRINTS = {'GitHub Pages': ['isn\\'t a GitHub Pages site here'], 'AWS S3': ['NoSuchBucket']}",
                        "",
                        "def check_takeover(domain):",
                        "    content = requests.get(f'http://{domain}').text",
                        "    for service, patterns in FINGERPRINTS.items():",
                        "        if any(p in content for p in patterns):",
                        "            print(f\"[!] {domain} vulnerable to {service} takeover\")"
                    ]
                }
            ]
