            "heading": "Bash Automation Patterns",
            "subheadings": [
                {
                    "heading": "Modular Reconnaissance Script",
                    "type": "code_block",
                    "content": [
                        "#!/bin/bash",
                        "# recon.sh - Automated asset discovery pipeline",
                        "TARGET=$1; OUTPUT_DIR=\"./recon/$TARGET\"; mkdir -p \"$OUTPUT_DIR\"",
                        "",
                        "# Subdomain enumeration (Passive + Active)",
                        "subfinder -d \"$TARGET\" -silent | tee \"$OUTPUT_DIR/subdomains.txt\"",
                        "amass enum -passive -d \"$TARGET\" >> \"$OUTPUT_DIR/subdomains.txt\"",
                        "sort -u \"$OUTPUT_DIR/subdomains.txt\" -o \"$OUTPUT_DIR/subdomains.txt\"",
                        "",
                        "# Resolution & Port Scanning",
                        "cat \"$OUTPUT_DIR/subdomains.txt\" | httpx -silent | tee \"$OUTPUT_DIR/alive.txt\"",
                        "naabu -l \"$OUTPUT_DIR/subdomains.txt\" -silent | tee \"$OUTPUT_DIR/ports.txt\""
                    ]
                },
                {
                    "heading": "Parallel Processing & Threading",
                    "type": "code_block",
                    "content": [
                        "# High-speed URL status checking with GNU Parallel",
                        "cat urls.txt | parallel -j 50 \"curl -s -o /dev/null -w '%{http_code} {}\\n' {}\"",
                        "",
                        "# Progress-aware directory bruteforce with ffuf",
                        "ffuf -u \"$TARGET/FUZZ\" -w \"$WORDLIST\" -t 100 -mc 200,403 -o results.json -of json"
                    ]
                }
            ]
